{
  "name": "lithosphere-dnns",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @litho/dnns-sdk && npm run build -w @litho/dnns-api",
